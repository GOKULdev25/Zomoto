# Groq LLM configuration
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3

# HuggingFace dataset
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation

# HuggingFace Inference API — for FLUX.1-schnell restaurant image generation
# Get your free token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Local cache path for preprocessed restaurant data
DATA_CACHE_PATH=data/restaurants.parquet

# Recommendation pipeline tuning
MAX_CANDIDATES_FOR_LLM=20
TOP_K_RECOMMENDATIONS=5

# Budget tier thresholds (INR, cost for two)
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500

# ── Deployment (set these on Railway) ──────────────────────
# PORT is auto-injected by Railway — do NOT set manually
# FRONTEND_URL: your Vercel production URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

